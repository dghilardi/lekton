# Lekton Environment Configuration
# Copy this file to .env and update with your actual values

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=lekton

# S3 Storage Configuration
# Get these credentials from garage-init output: docker-compose logs garage-init
S3_BUCKET=lekton-docs
S3_ENDPOINT=http://localhost:3900
AWS_ACCESS_KEY_ID=YOUR_GARAGE_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_GARAGE_SECRET_KEY_HERE
AWS_REGION=garage

# Service Token for API ingestion
# This token is used by CI/CD to push documentation updates
SERVICE_TOKEN=demo-ingest-token

# Meilisearch Configuration
# Full-text search engine for document indexing
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=dev-master-key-change-in-prod

# Demo Mode (bypasses OIDC authentication)
# Set to true for local development, false for production with real OIDC
DEMO_MODE=true

# OAuth2 / OIDC Authentication (required when DEMO_MODE=false)
# AUTH_PROVIDER_TYPE=oauth2           # "oidc" (default) or "oauth2"
# AUTH_CLIENT_ID=your-client-id
# AUTH_CLIENT_SECRET=your-client-secret
# AUTH_REDIRECT_URI=http://localhost:3000/auth/callback
# AUTH_AUTHORIZATION_ENDPOINT=https://provider.example.com/oauth/authorize
# AUTH_TOKEN_ENDPOINT=https://provider.example.com/oauth/token
# AUTH_USERINFO_ENDPOINT=https://provider.example.com/userinfo
# AUTH_SCOPES=openid profile email
#
# JWT settings
# JWT_SECRET=change-me-in-production
# JWT_ACCESS_TTL_SECS=900
# JWT_REFRESH_TTL_DAYS=30
#
# Custom userinfo field mapping (dot-notation, for non-standard providers)
# AUTH_USERINFO_SUB_FIELD=data.userShortId
# AUTH_USERINFO_EMAIL_FIELD=data.loginEmail
# AUTH_USERINFO_NAME_FIELD=data.firstName,data.lastName

# Logging
RUST_LOG=lekton=info,tower_http=info

# Leptos Configuration
LEPTOS_SITE_ADDR=127.0.0.1:3000
