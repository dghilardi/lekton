# Lekton Environment Configuration
#
# Configuration is loaded in priority order (highest wins):
#   1. LKN__* environment variables (this file)
#   2. config/lekton.toml (optional local file, git-ignored)
#   3. config/default.toml (embedded defaults)
#
# Env var naming: LKN__<SECTION>__<KEY>  (double underscore as separator)
# Example: LKN__DATABASE__URI maps to database.uri in the config struct.
#
# AWS credentials (S3) use the standard AWS_* env vars read by aws-config.
# LEPTOS_SITE_ADDR is managed by cargo-leptos (not part of LKN__ config).

# ── Database ────────────────────────────────────────────────────────────────────

LKN__DATABASE__URI=mongodb://localhost:27017
LKN__DATABASE__NAME=lekton

# Optional: inject credentials separately instead of embedding them in the URI
# LKN__DATABASE__USERNAME=myuser
# LKN__DATABASE__PASSWORD=mypassword

# ── S3 Storage ─────────────────────────────────────────────────────────────────
# AWS credentials are read by aws-config from the standard AWS_* env vars.

LKN__STORAGE__BUCKET=lekton-docs
LKN__STORAGE__ENDPOINT=http://localhost:3900   # custom endpoint for Garage/MinIO

AWS_ACCESS_KEY_ID=YOUR_GARAGE_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_GARAGE_SECRET_KEY_HERE
AWS_REGION=garage

# ── Meilisearch ────────────────────────────────────────────────────────────────
# Leave LKN__SEARCH__URL unset (or empty) to disable full-text search.

LKN__SEARCH__URL=http://localhost:7700
LKN__SEARCH__API_KEY=dev-master-key-change-in-prod

# ── Authentication ─────────────────────────────────────────────────────────────

# Service token used by CI/CD for ingestion endpoints
LKN__AUTH__SERVICE_TOKEN=demo-ingest-token

# Demo mode: built-in username/password login (NOT for production)
LKN__AUTH__DEMO_MODE=true

# JWT settings (required when demo_mode = false)
# LKN__AUTH__JWT_SECRET=change-me-in-production
# LKN__AUTH__JWT_ACCESS_TTL_SECS=900
# LKN__AUTH__JWT_REFRESH_TTL_DAYS=30

# OAuth2 / OIDC (required when demo_mode = false)
# LKN__AUTH__PROVIDER_TYPE=oidc          # "oidc" (default) or "oauth2"
# LKN__AUTH__CLIENT_ID=your-client-id
# LKN__AUTH__CLIENT_SECRET=your-client-secret
# LKN__AUTH__REDIRECT_URI=http://localhost:3000/auth/callback
# LKN__AUTH__AUTHORIZATION_ENDPOINT=https://provider.example.com/oauth/authorize
# LKN__AUTH__TOKEN_ENDPOINT=https://provider.example.com/oauth/token
# LKN__AUTH__USERINFO_ENDPOINT=https://provider.example.com/userinfo
# LKN__AUTH__SCOPES=openid profile email
#
# Custom userinfo field mapping (dot-notation, for non-standard providers)
# LKN__AUTH__USERINFO_SUB_FIELD=data.userShortId
# LKN__AUTH__USERINFO_EMAIL_FIELD=data.loginEmail
# LKN__AUTH__USERINFO_NAME_FIELD=data.firstName,data.lastName

# ── Server ─────────────────────────────────────────────────────────────────────

# Allow non-HTTPS cookies (required for HTTP local dev)
# LKN__SERVER__INSECURE_COOKIES=true

# Comma-separated allowed CORS origins (unset = same-origin only)
# LKN__SERVER__CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Rate limiter burst size (default: 50)
# LKN__SERVER__RATE_LIMIT_BURST=50

# Maximum attachment upload size in MB (default: 25)
# LKN__SERVER__MAX_ATTACHMENT_SIZE_MB=25

# Tracing filter (used when RUST_LOG is not set)
# LKN__SERVER__LOG_FILTER=lekton=info,tower_http=info

# ── Leptos / cargo-leptos ──────────────────────────────────────────────────────
# These are managed by cargo-leptos, not by LKN_ config.

LEPTOS_SITE_ADDR=127.0.0.1:3000
